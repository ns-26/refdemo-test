{
  "definitions": [
    {
      "title": "Tabs",
      "id": "tabs",
      "model": "tabs",
      "filter": "tabs",
      "plugins": {
        "da": {
          "rows": 0,
          "columns": 0
        }
      }
    },
    {
      "title": "Tabs Item",
      "id": "tabs-item",
      "model": "tabs-item",
      "plugins": {
        "da": {
          "rows": 1,
          "columns": 2,
          "fields": [
            { "name": "title", "selector": "div:nth-child(1)>p:nth-child(1)" },
            { "name": "heading", "selector": "div:nth-child(2)>p:nth-child(1)" },
            { "name": "headingType", "selector": "div:nth-child(3)>p:nth-child(1)" },
            { "name": "image", "selector": "picture>img[src]" },
            { "name": "imageAlt", "selector": "picture>img[alt]" },
            { "name": "content", "selector": "div:nth-child(5)>p:nth-child(1)" }
          ]
        }
      }
    }
  ],
  "models": [
    {
      "id": "tabs-item",
      "fields": [
        {
          "component": "text",
          "name": "title",
          "valueType": "string",
          "label": "Tab Name",
          "multi": false,
          "value": ""
        },
        {
          "component": "text",
          "name": "heading",
          "valueType": "string",
          "label": "Heading",
          "multi": false,
          "value": ""
        },
        {
          "component": "text",
          "name": "subheading",
          "valueType": "string",
          "label": "Subheading",
          "multi": false,
          "value": ""
        },
        {
          "component": "reference",
          "valueType": "string",
          "name": "image",
          "label": "Image",
          "multi": false
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "imageAlt",
          "label": "Image Alt Text",
          "multi": false
        },
        {
          "component": "richtext",
          "name": "content",
          "label": "Content",
          "valueType": "string",
          "value": ""
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "tabs",
      "components": [
        "tabs-item"
      ]
    }
  ]
}
